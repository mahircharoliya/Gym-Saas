generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  domain             String?      @unique
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  address            String?
  email              String?
  emailNotifications Boolean      @default(true)
  logoUrl            String?
  phone              String?
  smsNotifications   Boolean      @default(false)
  timezone           String       @default("America/New_York")
  invites            Invite[]
  products           Product[]
  signupForms        SignupForm[]
  users              User[]
  waivers            Waiver[]
}

model User {
  id             String          @id @default(cuid())
  tenantId       String
  email          String
  hashedPassword String?
  firstName      String
  lastName       String
  phone          String?
  role           Role            @default(MEMBER)
  emailVerified  Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  checkIns       CheckIn[]
  classBookings  ClassBooking[]
  trainerClasses GymClass[]      @relation("TrainerClasses")
  invites        Invite[]
  memberProducts MemberProduct[]
  signedWaivers  SignedWaiver[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])

  emailReminders  Boolean  @default(true)
  smsReminders    Boolean  @default(false)
}

model Invite {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       Role      @default(MEMBER)
  token      String    @unique
  invitedBy  String
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  inviter    User      @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
}

model Product {
  id              String          @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  membershipType  MembershipType
  status          ProductStatus   @default(ACTIVE)
  price           Decimal         @db.Decimal(10, 2)
  comparePrice    Decimal?        @db.Decimal(10, 2)
  billingInterval BillingInterval @default(ONCE)
  visitLimit      Int?
  durationDays    Int?
  discountPercent Decimal?        @db.Decimal(5, 2)
  discountEndsAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  memberProducts  MemberProduct[]
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model MemberProduct {
  id                    String              @id @default(cuid())
  tenantId              String
  userId                String
  productId             String
  status                MemberProductStatus @default(ACTIVE)
  visitsRemaining       Int?
  activatedAt           DateTime            @default(now())
  expiresAt             DateTime?
  cancelledAt           DateTime?
  authNetCustomerId     String?
  authNetSubscriptionId String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([productId])
}

model SignupForm {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  isActive    Boolean      @default(true)
  productIds  String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  waivers     FormWaiver[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Waiver {
  id            String         @id @default(cuid())
  tenantId      String
  title         String
  body          String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  formWaivers   FormWaiver[]
  signedWaivers SignedWaiver[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model FormWaiver {
  id           String     @id @default(cuid())
  signupFormId String
  waiverId     String
  order        Int        @default(0)
  signupForm   SignupForm @relation(fields: [signupFormId], references: [id], onDelete: Cascade)
  waiver       Waiver     @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@unique([signupFormId, waiverId])
}

model SignedWaiver {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  waiverId  String
  ipAddress String?
  signedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waiver    Waiver   @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@unique([userId, waiverId])
  @@index([tenantId])
  @@index([userId])
}

model CheckIn {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  method    String   @default("MANUAL")
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, createdAt])
}

model GymClass {
  id          String         @id @default(cuid())
  tenantId    String
  trainerId   String?
  name        String
  description String?
  location    String?
  color       String         @default("#6366f1")
  capacity    Int            @default(20)
  status      ClassStatus    @default(SCHEDULED)
  startAt     DateTime
  endAt       DateTime
  isRecurring Boolean        @default(false)
  recurringId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  bookings    ClassBooking[]
  trainer     User?          @relation("TrainerClasses", fields: [trainerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@index([recurringId])
}

model ClassBooking {
  id          String        @id @default(cuid())
  tenantId    String
  classId     String
  userId      String
  status      BookingStatus @default(CONFIRMED)
  bookedAt    DateTime      @default(now())
  cancelledAt DateTime?
  gymClass    GymClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([tenantId])
  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  TRAINER
  MEMBER
}

enum MembershipType {
  FULL_ACCESS
  LIMITED_VISITS
  TIME_BASED
  CLASS_BASED
}

enum BillingInterval {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum MemberProductStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  WAITLISTED
}
